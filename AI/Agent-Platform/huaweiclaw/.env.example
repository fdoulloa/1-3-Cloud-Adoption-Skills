# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=""
TELEGRAM_ALLOWED_USER_IDS=""

# LLM Configuration (OpenAI-compatible API)
OPENAI_BASE_URL=""
OPENAI_API_KEY=""
# Agent LLM assignments (optimized for speed + intent)
ORCHESTRATOR_LLM_MODEL="deepseek-v3.1-terminus"   # Fastest (0.8s) - routing/classification
HUAWEI_LLM_MODEL="DeepSeek-V3"                    # Fast + precise - API tool execution
CODE_LLM_MODEL="deepseek-v4-flash"                # Speed + quality - code generation/debug
DATA_LLM_MODEL="DeepSeek-V3"                     # Higher rate limit - SQL queries + charts (deepseek-v4-flash limited to 3 req/min)
COMMUNICATION_LLM_MODEL="qwen3-32b"               # Very fast - short tasks in Spanish
KNOWLEDGE_LLM_MODEL="DeepSeek-V3"                 # Balanced - knowledge/RAG responses
BUSINESS_LLM_MODEL="DeepSeek-V3"                  # Fast + good reasoning - business analysis
# Default fallback for any unassigned agent
DEFAULT_LLM_MODEL="DeepSeek-V3"

# MongoDB Configuration
MONGODB_URI="mongodb://localhost:27017/huaweiclaw"

# Agent Settings
MAX_ITERATIONS="10"
TIMEOUT_MS="120000"
LOG_LEVEL="info"

# Deepgram (TTS/STT)
DEEPGRAM_API_KEY=""
DEEPGRAM_TTS_MODEL="aura-2-celeste-es"
DEEPGRAM_STT_MODEL="nova-2"

# Server Ports
MCP_WEB_PORT=3001
MCP_PORT=3000

# Huawei Cloud Credentials
HUAWEI_ACCESS_KEY=""
HUAWEI_SECRET_KEY=""

# Vector Store (Weaviate)
VECTOR_STORE_TYPE="WEAVIATE"
WEAVIATE_URL="http://localhost:8080"
WEAVIATE_API_KEY=""

# Ollama Embeddings
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_EMBED_MODEL="bge-m3"

# Zaturn Data Sources (comma-separated connection strings)
# Example: mysql://user:pass@host:3306/dbname
ZATURN_SOURCES=""

# Google OAuth (for Google Workspace SDK)
# Run: open http://localhost:3001/api/google/auth to get tokens
GOOGLE_REDIRECT_URI=""
GOOGLE_ACCESS_TOKEN=""
GOOGLE_REFRESH_TOKEN=""

# WhatsApp Business API (Meta Cloud API)
# WHATSAPP_TOKEN=""
# WHATSAPP_PHONE_NUMBER_ID=""
# WHATSAPP_VERIFY_TOKEN="huaweiclaw_verify"
# WHATSAPP_ALLOWED_NUMBERS=""

# Docker Sandbox (for run_python)
SANDBOX_DOCKER_IMAGE="python:3.12-slim"
SANDBOX_TIMEOUT_MS="30000"
SANDBOX_MAX_MEMORY="128m"
PYTHONPATH=""
