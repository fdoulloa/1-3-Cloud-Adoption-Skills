# file: .env
# ============================================================
# CSS CLUSTER CONFIGURATION
# ============================================================
CSS_HOST=your_css_host_ip
CSS_PORT=9200
CSS_USERNAME=your_css_username
CSS_PASSWORD=your_css_password
CSS_CLUSTER_ID=your_css_cluster_id
INDEX_NAME=benchmark_vectors
VECTOR_DIMENSION=128

# ============================================================
# HUAWEI CLOUD API CREDENTIALS (para autoescalamiento)
# ============================================================
HW_ACCESS_KEY=your_huawei_access_key
HW_SECRET_KEY=your_huawei_secret_key
HW_PROJECT_ID=your_huawei_project_id
HW_REGION=la-north-2

# ============================================================
# BENCHMARK CONFIGURATION
# ============================================================
INGESTION_TOTAL_VECTORS=10000
INGESTION_BATCH_SIZE=100
EVAL_N_QUERIES=100
EVAL_CORPUS_SIZE=1000

# ============================================================
# AUTOSCALING THRESHOLDS
# ============================================================
# Lowered thresholds to trigger autoscaling more easily during stress tests
SCALE_OUT_CPU_THRESHOLD=75
SCALE_OUT_HEAP_THRESHOLD=80
SCALE_OUT_DISK_THRESHOLD=75
SCALE_IN_CPU_THRESHOLD=30
SCALE_IN_HEAP_THRESHOLD=40
SCALE_IN_DISK_THRESHOLD=40
MIN_DATA_NODES=1
MAX_DATA_NODES=10
SCALE_OUT_COOLDOWN=180
SCALE_IN_COOLDOWN=300
MONITOR_INTERVAL=10

# ============================================================
# PHASE 5 CONTROLLER CONFIGURATION
# ============================================================
# Intervalo de verificación de métricas (segundos)
PHASE5_CHECK_INTERVAL=10
# Tiempo objetivo para detectar scale out (segundos)
PHASE5_SCALE_OUT_TARGET_TIME=180
# Tiempo objetivo para detectar scale in (segundos)
PHASE5_SCALE_IN_TARGET_TIME=300
# Máximo de reintentos antes de asumir scale out exitoso
PHASE5_MAX_SCALE_OUT_RETRIES=5
# Máximo de iteraciones totales (seguridad contra loops infinitos)
PHASE5_MAX_TOTAL_ITERATIONS=500
# Tiempo de cooldown después de scale out (segundos)
PHASE5_COOLDOWN_TIME=60
