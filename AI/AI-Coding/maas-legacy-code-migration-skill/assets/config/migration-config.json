{
  "batch_size": 10,
  "languages": ["java", "cobol", "dotnet"],
  "characterization_test_frameworks": {
    "java": "junit5",
    "cobol": "golden-file",
    "dotnet": "xunit"
  },
  "stop_on_batch_failure": true,
  "require_human_review": true,
  "degrees_of_freedom": "low",
  "max_retries_per_batch": 2,
  "done_list": "done.list",
  "max_files_per_analysis": 50,
  "max_file_size_bytes": 51200,
  "maas": {
    "base_url": "https://api-ap-southeast-1.modelarts-maas.com/openai/v1",
    "model": "glm-5.1",
    "api_key_env": "API_KEY",
    "analysis_max_tokens": 4096,
    "plan_max_tokens": 8192,
    "transform_max_tokens": 16384,
    "temperature": 0.1
  }
}
