{
  "block_on_severity": "high",
  "review_persona": "code-reviewer",
  "security_persona": "security-auditor",
  "excluded_paths": [
    "vendor/",
    "node_modules/",
    ".git/",
    "__pycache__/",
    "*.min.js",
    "*.min.css"
  ],
  "owasp_categories": [
    "A01", "A02", "A03", "A04", "A05",
    "A06", "A07", "A08", "A09", "A10"
  ],
  "report_format": "markdown",
  "max_findings_per_file": 50,
  "max_file_size_bytes": 51200,
  "maas": {
    "base_url": "https://api-ap-southeast-1.modelarts-maas.com/openai/v1",
    "model": "glm-5.1",
    "api_key_env": "API_KEY",
    "max_tokens": 4096,
    "temperature": 0.1
  }
}
