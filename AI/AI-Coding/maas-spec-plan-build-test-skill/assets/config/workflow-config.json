{
  "phases": ["spec", "plan", "build", "test"],
  "gates": {
    "spec": {
      "auto": true,
      "criteria": "all_criteria_testable",
      "max_iterations": 3
    },
    "plan": {
      "auto": false,
      "criteria": "human_approval",
      "max_iterations": 2
    },
    "build": {
      "auto": true,
      "criteria": "quality_gate_passes",
      "delegate": "maas-ai-coding-quality-skill"
    },
    "test": {
      "auto": true,
      "criteria": "all_tests_pass_and_coverage_met"
    }
  },
  "vertical_slicing": true,
  "max_spec_iterations": 3,
  "max_plan_iterations": 2,
  "maas": {
    "base_url": "https://api-ap-southeast-1.modelarts-maas.com/openai/v1",
    "model": "glm-5.1",
    "api_key_env": "API_KEY",
    "spec_max_tokens": 8192,
    "plan_max_tokens": 8192,
    "build_max_tokens": 32768,
    "test_max_tokens": 16384
  }
}
