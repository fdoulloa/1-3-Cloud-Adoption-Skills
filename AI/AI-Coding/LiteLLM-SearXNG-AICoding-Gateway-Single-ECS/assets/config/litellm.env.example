LITELLM_MASTER_KEY=sk-replace-with-master-key
DATABASE_URL=postgresql://litellm:replace-with-pg-password@127.0.0.1:5432/litellm
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=replace-with-redis-password
HUAWEI_MAAS_API_BASE=https://api-ap-southeast-1.modelarts-maas.com/openai/v1
HUAWEI_MAAS_API_KEY=replace-with-huawei-maas-api-key

# Required so LiteLLM's startup subprocess.run(["prisma"]) finds the CLI under systemd.
PATH=/opt/litellm-venv/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

# Required so the Prisma config loader (~ / pyproject.toml) is readable by the litellm user.
HOME=/opt/litellm

# Pin the Prisma query engine binary path. Fill in the actual binary location after
# running `prisma generate` once. Example:
# PRISMA_QUERY_ENGINE_BINARY=/opt/litellm/.cache/prisma-python/binaries/5.17.0/<sha>/node_modules/prisma/query-engine-debian-openssl-3.0.x
PRISMA_QUERY_ENGINE_BINARY=
