{
  "index_patterns": ["ops_metrics-*"],
  "template": {
    "settings": {
      "number_of_shards": 3,
      "number_of_replicas": 1,
      "refresh_interval": "5s"
    },
    "mappings": {
      "properties": {
        "timestamp": {"type": "date", "format": "strict_date_optional_time||epoch_millis"},
        "metric_name": {"type": "keyword"},
        "namespace": {"type": "keyword"},
        "resource_id": {"type": "keyword"},
        "resource_type": {"type": "keyword"},
        "resource_name": {"type": "keyword"},
        "region": {"type": "keyword"},
        "value": {"type": "double"},
        "unit": {"type": "keyword"},
        "source": {"type": "keyword"},
        "correlation_id": {"type": "keyword"},
        "dimensions": {"type": "nested", "properties": {
          "name": {"type": "keyword"},
          "value": {"type": "keyword"}
        }}
      }
    }
  }
}
