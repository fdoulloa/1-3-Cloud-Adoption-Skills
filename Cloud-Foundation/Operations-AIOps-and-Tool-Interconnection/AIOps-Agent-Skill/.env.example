# Huawei Cloud credentials
HWC_ACCESS_KEY_ID=
HWC_SECRET_ACCESS_KEY=
HWC_REGION=la-north-2
HWC_PROJECT_ID=

# CSS cluster
CSS_CLUSTER_ID=
CSS_ENDPOINT=
CSS_USERNAME=admin
CSS_PASSWORD=

# MaaS LLM
HUAWEI_MAAS_API_BASE=https://maas-api.la-north-2.myhuaweicloud.com/v1
HUAWEI_MAAS_API_KEY=
HUAWEI_MAAS_MODEL=glm-5.1

# AOM/CES monitoring
AOM_APP_ID=

# Prometheus (optional)
PROMETHEUS_URL=http://localhost:9090
GRAFANA_URL=http://localhost:3000
GRAFANA_API_KEY=

# LTS ingestion
LTS_LOG_GROUP_ID=
LTS_LOG_TOPIC_ID=

# CTS
CTS_TRACKER_NAME=system

# SMN approval notifications
SMN_TOPIC_URN=
SMN_APPROVAL_EMAIL=

# OBS for reports and state
OBS_BUCKET_NAME=
OBS_REGION=la-north-2

# Approval token
APPROVAL_TTL_SECONDS=900

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=
TRACELOOP_TRACE_CONTENT=false

# Agent config
AGENT_VERSION=1.0.0
VERIFICATION_DELAY_SECONDS=30
MAX_REDIAGNOSIS_LOOPS=2
DEMO_MODE=false
