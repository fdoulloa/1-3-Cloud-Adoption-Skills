# Optional real Teradata source settings.
# The default demo source is the local tdsim Citus/PostgreSQL cluster.

TERADATA_HOST=replace-with-teradata-host
TERADATA_USER=replace-with-teradata-user
TERADATA_PASSWORD=replace-with-teradata-password
TERADATA_DATABASE=finance_dw

# If using JDBC export, provide the Teradata JDBC jar path.
TERADATA_JDBC_JAR=/path/to/terajdbc4.jar

