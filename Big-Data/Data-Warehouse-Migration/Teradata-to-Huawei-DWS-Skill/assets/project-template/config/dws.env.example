# Copy to config/dws.env and fill values for the target Huawei Cloud DWS cluster.
# Do not commit config/dws.env.

DWS_HOST=replace-with-dws-private-or-public-endpoint
DWS_PORT=8000
DWS_DATABASE=postgres
DWS_USER=dbadmin
DWS_PASSWORD=replace-with-dws-admin-password

# prefer, require, disable
DWS_SSLMODE=prefer

# Keep this as docker on this host because the local psql has a libldap/OpenSSL issue.
DWS_SQL_CLIENT=docker
DWS_SQL_CLIENT_IMAGE=citusdata/citus:12.1

